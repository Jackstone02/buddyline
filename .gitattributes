# Normalize all text files to LF in the repo and on checkout.
# Silences "LF will be replaced by CRLF" warnings on Windows and keeps
# line endings consistent across macOS/Linux/Windows (JS/RN expects LF).
* text=auto eol=lf

# Shell scripts must stay LF
*.sh text eol=lf

# Windows-specific scripts stay CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary assets — never convert
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.jks binary
*.keystore binary
*.p8 binary
*.p12 binary
*.mp4 binary
*.zip binary
