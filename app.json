{
  "expo": {
    "name": "Buddyline",
    "slug": "buddyline",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/buddyline-2.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "scheme": [
      "buddyline",
      "com.buddyline.app"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.buddyline.app",
      "usesAppleSignIn": true,
      "config": {
        "googleMapsApiKey": "AIzaSyDcaDaB4hdR4SGGGotR7l8saIR8Zp_zPY0"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Buddyline needs your location to show nearby divers and instructors.",
        "NSCameraUsageDescription": "Buddyline needs camera access for profile photos and certifications.",
        "NSPhotoLibraryUsageDescription": "Buddyline needs photo library access to upload profile photos and certifications.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.buddyline.app",
      "googleServicesFile": "./google-services.json",
      "predictiveBackGestureEnabled": false,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDcaDaB4hdR4SGGGotR7l8saIR8Zp_zPY0"
        }
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "manwqkdbajvidgmtrvzy.supabase.co",
              "pathPrefix": "/auth/v1/callback"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/buddyline-2.png"
    },
    "plugins": [
      "expo-location",
      "expo-asset",
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Buddyline to access your photos for profile pictures and certifications.",
          "cameraPermission": "Allow Buddyline to access your camera."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1CA7A6",
          "sounds": []
        }
      ]
    ],
    "owner": "jackstone",
    "extra": {
      "eas": {
        "projectId": "9f683cf8-f13d-428d-b31a-5f3135929e86"
      }
    }
  }
}
