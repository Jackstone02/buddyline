{
  "expo": {
    "name": "Buddy Up",
    "slug": "buddy-up",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0369A1"
    },
    "scheme": [
      "buddyup",
      "com.buddyup.app"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.buddyup.app",
      "usesAppleSignIn": true,
      "config": {
        "googleMapsApiKey": "AIzaSyDcaDaB4hdR4SGGGotR7l8saIR8Zp_zPY0"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Buddy Up needs your location to show nearby divers and instructors.",
        "NSCameraUsageDescription": "Buddy Up needs camera access for profile photos and certifications.",
        "NSPhotoLibraryUsageDescription": "Buddy Up needs photo library access to upload profile photos and certifications."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.buddyup.app",
      "predictiveBackGestureEnabled": false,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDcaDaB4hdR4SGGGotR7l8saIR8Zp_zPY0"
        }
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "sivmbewtkqlvcbilgyjw.supabase.co",
              "pathPrefix": "/auth/v1/callback"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-location",
      "expo-asset",
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Buddy Up to access your photos for profile pictures and certifications.",
          "cameraPermission": "Allow Buddy Up to access your camera."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "2c2d1fee-667d-4ef9-ab53-4cb5ad6d0231"
      }
    }
  }
}
